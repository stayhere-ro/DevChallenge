{
    "openapi": "3.0.0",
    "info": {
        "title": "Hairdresser Booking App",
        "description": "This is a web application for hairdresser booking",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://devchallenge.test",
            "description": "Local Development Server"
        }
    ],
    "paths": {
        "/api/bookings": {
            "get": {
                "tags": [
                    "Bookings"
                ],
                "summary": "List bookings by email",
                "operationId": "892e999e621adf64f793434dc92e0ea6",
                "parameters": [
                    {
                        "name": "email",
                        "in": "query",
                        "description": "Filter bookings by customer email",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "email",
                            "example": "testuser@example.com"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "example": {
                                            "id": 6,
                                            "hairdresser_id": 5,
                                            "user_id": 1,
                                            "name": "Test User",
                                            "email": "testuser@example.com",
                                            "scheduled_at": "2026-01-12T08:00:00.000000Z",
                                            "created_at": "2026-01-04T19:28:45.000000Z",
                                            "updated_at": "2026-01-04T19:28:45.000000Z"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "No bookings found"
                    }
                }
            },
            "post": {
                "tags": [
                    "Bookings"
                ],
                "summary": "Create a new booking",
                "operationId": "93d8dd55a19ee4c15b3e974b3b38c787",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "hairdresser_id",
                                    "date",
                                    "hour",
                                    "name",
                                    "email"
                                ],
                                "properties": {
                                    "hairdresser_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2026-03-10"
                                    },
                                    "hour": {
                                        "type": "string",
                                        "example": "13:00"
                                    },
                                    "name": {
                                        "type": "string",
                                        "example": "John Doe"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "johndoe@email.com"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Booking Created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Booking created successfully"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "The given data was invalid."
                                        },
                                        "errors": {
                                            "type": "object",
                                            "example": {
                                                "date": [
                                                    "The date cannot be on weekends."
                                                ],
                                                "hour": [
                                                    "The selected time slot is already taken."
                                                ]
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "tags": [
        {
            "name": "Bookings",
            "description": "Bookings"
        }
    ]
}